# Septic Systems HQ - Environment Variables
# Moonshot AI API key for content generation (https://platform.moonshot.ai/console/api-keys)
MOONSHOT_API_KEY=your_api_key_here

# Optional: n8n webhook URL for form submissions
# N8N_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/xxx

# Optional: GA4 measurement ID
# GA4_ID=G-XXXXXXXXXX
